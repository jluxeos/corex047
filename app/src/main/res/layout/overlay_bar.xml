<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingHorizontal="12dp"
    android:paddingBottom="16dp">

    <LinearLayout
        android:id="@+id/panelExpanded"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@drawable/overlay_bg"
        android:layout_marginBottom="8dp"
        android:elevation="8dp">

        <View
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="4dp"
            android:background="#79747E"
            android:alpha="0.4"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tabChat"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Chat"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#6750A4"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tabHistorial"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Log"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#79747E"/>

            <TextView
                android:id="@+id/tabDebug"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Debug"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#79747E"/>

            <TextView
                android:id="@+id/tabAjustes"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Ajustes"
                android:gravity="center"
                android:textSize="13sp"
                android:textColor="#79747E"/>

        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E7E0EC"/>

        <!-- Historial -->
        <ScrollView
            android:id="@+id/scrollHistorial"
            android:layout_width="match_parent"
            android:layout_height="240dp">
            <TextView
                android:id="@+id/tvHistorial"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Sin historial aún"
                android:textSize="12sp"
                android:textColor="#1C1B1F"/>
        </ScrollView>

        <!-- Chat -->
        <ScrollView
            android:id="@+id/scrollChat"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvChat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Hola! Soy Corex. Dime qué necesitas."
                android:textSize="13sp"
                android:lineSpacingExtra="4dp"
                android:textColor="#1C1B1F"/>
        </ScrollView>

        <!-- Debug -->
        <ScrollView
            android:id="@+id/scrollDebug"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:visibility="gone">
            <TextView
                android:id="@+id/tvDebug"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="12dp"
                android:text="Sin datos aún"
                android:textSize="10sp"
                android:fontFamily="monospace"
                android:textColor="#1C1B1F"/>
        </ScrollView>

        <!-- Ajustes -->
        <LinearLayout
            android:id="@+id/panelAjustes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="API Key (Groq)"
                android:textSize="12sp"
                android:textColor="#6750A4"
                android:layout_marginBottom="4dp"/>

            <EditText
                android:id="@+id/etApiKey"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:hint="gsk_..."
                android:textSize="13sp"
                android:background="@drawable/input_bg"
                android:paddingHorizontal="12dp"
                android:inputType="textPassword"
                android:layout_marginBottom="12dp"/>

            <SeekBar
                android:id="@+id/seekDelay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:max="1500"
                android:progress="400"
                android:progressTint="#6750A4"
                android:thumbTint="#6750A4"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/tvDelayVal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="400ms"
                android:textSize="12sp"
                android:textColor="#79747E"
                android:layout_marginBottom="12dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnGuardar"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Guardar"
                    android:background="@drawable/btn_send_bg"
                    android:textColor="#FFFFFF"
                    android:layout_marginEnd="8dp"/>

                <Button
                    android:id="@+id/btnExport"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="Exportar caché"
                    android:background="@drawable/btn_tonal_bg"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

    <!-- Panel picker -->
    <LinearLayout
        android:id="@+id/panelPicker"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="@drawable/overlay_bg"
        android:layout_marginBottom="8dp"
        android:elevation="8dp"
        android:padding="12dp">

        <TextView
            android:id="@+id/tvPickerTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="¿Cuál es la correcta?"
            android:textSize="13sp"
            android:textColor="#6750A4"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="200dp">
            <androidx.gridlayout.widget.GridLayout
                android:id="@+id/pickerGrid"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:columnCount="4"/>
        </ScrollView>

        <!-- Botones de elementos de pantalla (scroll horizontal) -->
        <HorizontalScrollView
            android:id="@+id/pickerScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone">
            <LinearLayout
                android:id="@+id/pickerButtons"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"/>
        </HorizontalScrollView>

    </LinearLayout>

    <!-- Barra principal -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/overlay_bg"
        android:paddingHorizontal="12dp"
        android:elevation="8dp">

        <ImageButton
            android:id="@+id/btnClose"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:tint="#79747E"/>

        <EditText
            android:id="@+id/inputOverlay"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:hint="Pregunta o da una orden..."
            android:textSize="15sp"
            android:background="@null"
            android:singleLine="true"
            android:paddingHorizontal="8dp"
            android:textColor="#1C1B1F"
            android:textColorHint="#79747E"/>

        <ImageButton
            android:id="@+id/btnExpand"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/arrow_up_float"
            android:background="@android:color/transparent"
            android:padding="6dp"
            android:tint="#6750A4"/>

        <ImageButton
            android:id="@+id/btnSend"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@android:drawable/ic_menu_send"
            android:background="@drawable/btn_send_bg"
            android:padding="8dp"
            android:tint="#FFFFFF"/>

    </LinearLayout>

</LinearLayout>
